<Window x:Class="BimPathfinder.PathfinderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM-Pathfinder A* — Настройки"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>

        <!-- Стиль TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"           Value="#2D2D2D"/>
            <Setter Property="Foreground"           Value="#D4D4D4"/>
            <Setter Property="BorderBrush"          Value="#555"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="6 4"/>
            <Setter Property="Height"               Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"           Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#569CD6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"           Value="#2D2D2D"/>
            <Setter Property="Foreground"           Value="#D4D4D4"/>
            <Setter Property="BorderBrush"          Value="#555"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Height"               Value="28"/>
            <Setter Property="Padding"              Value="6 0"/>
        </Style>

        <!-- Стиль Label -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"           Value="#AAAAAA"/>
            <Setter Property="VerticalAlignment"    Value="Center"/>
            <Setter Property="Margin"               Value="0 0 8 0"/>
        </Style>

        <!-- Стиль кнопки (базовый) -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height"               Value="32"/>
            <Setter Property="Padding"              Value="16 0"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Cursor"               Value="Hand"/>
            <Setter Property="FontSize"             Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка «Отмена» -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background"   Value="#3A3A3A"/>
            <Setter Property="Foreground"   Value="#D4D4D4"/>
            <Setter Property="BorderBrush"  Value="#555"/>
        </Style>

        <!-- Кнопка «ОК» -->
        <Style x:Key="OkButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background"   Value="#0E639C"/>
            <Setter Property="Foreground"   Value="#FFFFFF"/>
            <Setter Property="BorderBrush"  Value="#1177BB"/>
        </Style>

        <!-- Разделитель -->
        <Style TargetType="Separator">
            <Setter Property="Background"   Value="#444"/>
            <Setter Property="Margin"       Value="0 8"/>
        </Style>

    </Window.Resources>

    <Border Padding="20">
        <StackPanel>

            <!-- ── Заголовок ───────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 16">
                <TextBlock Text="BIM-Pathfinder"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#569CD6"/>
                <TextBlock Text=" A*"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#4EC9B0"/>
            </StackPanel>

            <!-- ── Секция: Основные параметры ──────────────────────── -->
            <TextBlock Text="ОСНОВНЫЕ ПАРАМЕТРЫ"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#569CD6"
                       Margin="0 0 0 8"
                       />

            <Grid Margin="0 0 0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <!-- Тип системы -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип системы:"/>
                <ComboBox  Grid.Row="0" Grid.Column="1"
                           x:Name="CbSystem">
                    <ComboBoxItem Content="Труба (Pipe)"      IsSelected="True"/>
                    <ComboBoxItem Content="Воздуховод (Duct)"/>
                </ComboBox>

                <!-- Диаметр -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Диаметр / ширина (мм):"/>
                <TextBox   Grid.Row="1" Grid.Column="1"
                           x:Name="TbDiameter" Text="100"/>

                <!-- Шаг сетки -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Шаг сетки (мм):"/>
                <TextBox   Grid.Row="2" Grid.Column="1"
                           x:Name="TbGridStep" Text="200"/>

                <!-- MaxPierceThickness -->
                <TextBlock Grid.Row="3" Grid.Column="0">
                    <Run Text="MaxPierceThickness (мм):"/>
                </TextBlock>
                <TextBox   Grid.Row="3" Grid.Column="1"
                           x:Name="TbMaxPierce" Text="0"/>
            </Grid>

            <!-- Подсказка к MaxPierce -->
            <TextBlock Text="0 = строгий обход всех стен; &gt;0 = пробивка тонких стен со штрафом"
                       FontSize="11"
                       Foreground="#777"
                       TextWrapping="Wrap"
                       Margin="0 0 0 12"/>

            <Separator/>

            <!-- ── Секция: Штрафы ───────────────────────────────────── -->
            <TextBlock Text="ШТРАФЫ"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#569CD6"
                       Margin="0 0 0 8"/>

            <Grid Margin="0 0 0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <!-- P_turn -->
                <TextBlock Grid.Row="0" Grid.Column="0">
                    <Run Text="P"/>
                    <Run Text="turn" BaselineAlignment="Subscript" FontSize="10"/>
                    <Run Text=" — за поворот:"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="TbPenaltyTurn" Text="2.0"/>

                <!-- P_support -->
                <TextBlock Grid.Row="1" Grid.Column="0">
                    <Run Text="P"/>
                    <Run Text="support" BaselineAlignment="Subscript" FontSize="10"/>
                    <Run Text=" — в воздухе:"/>
                </TextBlock>
                <TextBox Grid.Row="1" Grid.Column="1"
                         x:Name="TbPenaltySupport" Text="0.5"/>

                <!-- P_pierce -->
                <TextBlock Grid.Row="2" Grid.Column="0">
                    <Run Text="P"/>
                    <Run Text="pierce" BaselineAlignment="Subscript" FontSize="10"/>
                    <Run Text=" — пробивка (за фут):"/>
                </TextBlock>
                <TextBox Grid.Row="2" Grid.Column="1"
                         x:Name="TbPenaltyPierce" Text="10.0"/>
            </Grid>

            <Separator/>

            <!-- ── Кнопки ───────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 8 0 0">
                <Button Content="Отмена"
                        Style="{StaticResource CancelButton}"
                        Width="80"
                        Margin="0 0 8 0"
                        Click="OnCancelClick"/>
                <Button Content="Выбрать точки →"
                        Style="{StaticResource OkButton}"
                        Width="130"
                        IsDefault="True"
                        Click="OnOkClick"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
